{
  "expo": {
    "name": "Kraken Messenger",
    "slug": "kraken-messenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kraken",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#00F2FF",
    "backgroundColor": "#0A0F1A",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kraken.messenger",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Разблокируйте скрытые чаты с помощью Face ID",
        "NSCameraUsageDescription": "Сканируйте QR-коды",
        "NSPhotoLibraryUsageDescription": "Выберите фото"
      }
    },
    "android": {
      "package": "com.kraken.messenger",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0F1A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0F1A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "kraken-messenger"
      }
    }
  }
}
