{
  "expo": {
    "name": "Kraken Messenger",
    "slug": "kraken-messenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kraken",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#00F2FF",
    "backgroundColor": "#0A0F1A",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kraken.messenger",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Отправка фото в чаты",
        "NSPhotoLibraryUsageDescription": "Выбор фото из галереи",
        "NSLocationWhenInUseUsageDescription": "Добавление геометок на фото",
        "NSMicrophoneUsageDescription": "Запись голосовых сообщений"
      }
    },
    "android": {
      "package": "com.kraken.messenger",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0F1A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Добавление геометок на фото при съёмке."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложению необходим доступ к вашим фото для отправки в чаты.",
          "cameraPermission": "Приложению необходим доступ к камере для съёмки фото."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0F1A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
